{
  "alias": ["grudge-game-data-hub.vercel.app"],
  "outputDirectory": "public",
  "redirects": [
    { "source": "/(.*)", "destination": "https://info.grudge-studio.com/$1", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}