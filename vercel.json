{
  "alias": ["info.grudge-studio.com", "grudge-game-data-hub.vercel.app"],
  "buildCommand": "node scripts/prefetch-objectstore.mjs",
  "outputDirectory": "docs",
  "rewrites": [
    { "source": "/data/:path*", "destination": "/data/:path*" }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
